+    gzip on;
+    access_log /var/snap/hauk/current/log/nginx-access.log;
+
+    server {
+        listen 8000;
+        server_name _;
+        root /snap/hauk/current/html;
+        index index.php index.html;
+
+        location / {
+            try_files $uri $uri/ /index.php?$args;
+        }
+
+        location ~ \.php$ {
+            fastcgi_pass unix:/var/snap/hauk/current/run/php-fpm.sock;
+            fastcgi_index index.php;
+            fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
+            include fastcgi_params;
+        }
+    }
